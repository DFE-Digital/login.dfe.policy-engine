{
  "name": "login.dfe.policy-engine",
  "version": "3.1.3",
  "description": "Applies access policies to determine available roles for users",
  "main": "lib/index.js",
  "scripts": {
    "dev:checks": "npm run lint && npm run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:report": "eslint . -f junit -o eslint-results.xml",
    "format": "prettier . --write",
    "test": "jest --runInBand --coverage",
    "test:report": "jest --coverage --reporters=default --reporters jest-junit --coverageReporters=clover",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DFE-Digital/login.dfe.policy-engine.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DFE-Digital/login.dfe.policy-engine/issues"
  },
  "homepage": "https://github.com/DFE-Digital/login.dfe.policy-engine#readme",
  "dependencies": {
    "lodash": "^4.17.20",
    "login.dfe.async-retry": "github:DFE-Digital/login.dfe.async-retry#v2.0.2",
    "login.dfe.jwt-strategies": "github:DFE-Digital/login.dfe.jwt-strategies#v4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "eslint": "^9.25.1",
    "eslint-formatter-junit": "^8.40.0",
    "eslint-plugin-jest": "^28.11.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "jest-cli": "^29.6.3",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": false,
    "clearMocks": true
  }
}
